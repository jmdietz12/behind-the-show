<span class="textbox">Marlon looks at Truman with a concerned expression and says, "Hey, you're starting so scare me, man. Are you okay? This isn't normal behavior. I think you should go talk to someone because you sound crazy right now. I don't even know what to say to you."</span>

<span class="bottom-left">[[Continue ->Truman Goes to Bed][$suspicion += 2]]</span>


:: StoryScript [script]
const backgrounds = {
    interview: "https://jmdietz12.github.io/behind-the-show/images/interview.png",
    tvScreens: "https://jmdietz12.github.io/behind-the-show/images/tv-screens.png",
  	videoPanel: "https://jmdietz12.github.io/behind-the-show/images/video_panel_blank.png",
};

$(document).on(':passagerender', function () {
    const bg = State.variables.bg;

    if (backgrounds[bg]) {
        document.body.style.backgroundImage = `url('${backgrounds[bg]}')`;
    }
});

:: StoryStylesheet [stylesheet]
body {
  background-attachment: fixed;
  background-size: contain; 
  min-height: 100vh;
  margin: 0;
  background-position: center center;
  background-repeat: no-repeat;
  background-color: black;
  transition: background-image 0.5s ease-in-out;
}

.bottom-left {
  position: absolute;
  bottom: 10%;
  left: 17%;
  width: 25%;
  text-align: left;

  background: rgba(0, 0, 0, 0.7);
  color: white;

  padding: 20px;
  border: 2px solid white;

  display: inline-block;
  text-align: center;
  font-family: "Silkscreen";

  font-size: 18px;
}

.bottom-right {
  position: absolute;
  bottom: 10%;
  right: 17%;
  width: 25%;

  background: rgba(0, 0, 0, 0.7);
  color: white;

  padding: 20px;
  border: 2px solid white;

  display: inline-block;
  text-align: center;
  font-family: "Silkscreen";

  font-size: 18px;
}

.top-left {
  position: absolute;
  top: 0.3%;
  left: 28.7%;
  width: 25%;
  text-align: left;
  font-size: 30px;
  color: white;
  text-shadow: 2px 2px 4px white;
}

.top-right {
  position: absolute;
  top: 0.3%;
  right: 18.8%;
  width: 25%;
  text-align: right;
  font-size: 30px;
  color: white;
  text-shadow: 2px 2px 4px white;
}

.textbox {
  position: absolute;
  top: 25%;
  left: 50%;
  transform: translate(-50%, -50%);

  background: rgba(0, 0, 0, 0.7);
  color: white;

  padding: 20px;
  border: 2px solid white;

  display: inline-block;
  text-align: center;
  font-family: "Silkscreen";

  font-size: 24px;
}

.meter-fill.funding-color {
  background-color: #FFEE00
}

.meter-container {
  width: 300px;
  height: 18px;
  background-color: #525273;
  overflow: hidden;
}

.meter-fill {
  height: 100%;
  width: 0%;
  background-color: #FFEE00;
  transition: width 0.4s ease-in-out;
}

@font-face {
	font-family: "Silkscreen";
	src: url(https://jmdietz12.github.io/behind-the-show/font/slkscr.ttf);
	font-style: normal;
	font-weight: normal;
}