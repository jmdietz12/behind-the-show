:: StoryScript [script]
const backgrounds = {
    interview: "https://jmdietz12.github.io/behind-the-show/images/interview.png",
    tvScreens: "https://jmdietz12.github.io/behind-the-show/images/tv-screens.png",
  	videoPanel: "https://jmdietz12.github.io/behind-the-show/images/video-panel.png",
};

$(document).on(':passagerender', function () {
    const bg = State.variables.bg;

    if (backgrounds[bg]) {
        document.body.style.backgroundImage = `url('${backgrounds[bg]}')`;
    }
});

