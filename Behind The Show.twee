:: StoryScript [script]
const backgrounds = {
    forest: "forest.jpg",
    castle: "castle.jpg",
    cave: "cave.jpg"
};

$(document).on(':passagerender', function () {
    let bg = State.variables.bg;
    if (backgrounds[bg]) {
        document.body.style.backgroundImage = `url('${backgrounds[bg]}')`;
    }
});

